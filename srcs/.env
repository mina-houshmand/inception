# Nginx service variables
DOMAIN_NAME=oshcheho.42.fr
CERTS_CRT=/etc/nginx/ssl/nginx-selfsigned.crt
CERTS_KEY=/etc/nginx/ssl/nginx-selfsigned.key

# WordPress service variables
WP_URL=https://oshcheho.42.fr
WP_TITLE=Inception
WP_ADMIN=superuser
WP_USER2=editor
WP_USER2_ROLE=editor
PHP_HOST=wordpress
PHP_PORT=9000
WP_EMAIL=oshcheho@student.42.fr
WP_ADMIN_EMAIL=oshcheho@student.42.fr
WP_USER2_EMAIL=editor@student.42.fr
WP_ADMIN_PASS_FILE=/var/secrets/wp_password.txt
WP_USER2_PASS_FILE=/var/secrets/wp_user2_password.txt
WP_DATA_PATH=${HOME:-${USERPROFILE}}/data/wordpress
WP_DB_PATH=${HOME:-${USERPROFILE}}/data/wordpress_db

# MariaDB service variables
MYSQL_DATABASE=wordpress
MYSQL_USER=wp_user
MYSQL_PASSWORD_FILE=/var/secrets/db_password.txt
MYSQL_ROOT_PASSWORD_FILE=/var/secrets/db_root_password.txt
DB_DATA_PATH=/var/lib/mysql

# Shared database variables (used by WordPress and MariaDB)
DB_HOST=mariadb
DB_NAME=wordpress
DB_USER=wp_user
DB_PASSWORD_FILE=/var/secrets/db_password.txt

# Adminer service variables
ADMINER_HOST=adminer
ADMINER_PORT=8080
STATIC_HOST=static
STATIC_PORT=80

# FTP service variables
FTP_PORT=21
FTP_USER=ftp
FTP_PASSWORD_FILE=/var/secrets/ftp_password.txt
